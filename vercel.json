{
  "version": 2,
  "builds": [
    { "src": "api/telegram.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/telegram", "methods": ["GET", "POST"], "dest": "/api/telegram.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
